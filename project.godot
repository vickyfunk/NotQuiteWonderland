; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NotQuiteWonderland"
run/main_scene="res://testscene.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

BeehaveGlobalMetrics="*res://addons/beehave/metrics/beehave_global_metrics.gd"
BeehaveGlobalDebugger="*res://addons/beehave/debug/global_debugger.gd"
SoundManager="*res://addons/sound_manager/sound_manager.gd"
CyclopsAutoload="res://addons/cyclops_level_builder/cyclops_global_scene.tscn"
Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"

[dialogic]

directories/dch_directory={}
directories/dtl_directory={}

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[editor_plugins]

enabled=PackedStringArray("res://addons/anim_player_refactor/plugin.cfg", "res://addons/beehave/plugin.cfg", "res://addons/dialogic/plugin.cfg", "res://addons/gui_auto_layout/plugin.cfg", "res://addons/sound_manager/plugin.cfg", "res://addons/wigglebone/plugin.cfg")

